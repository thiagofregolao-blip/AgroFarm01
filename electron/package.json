{
  "name": "agrofarm-digital",
  "version": "1.0.0",
  "description": "AgroFarm Digital — Gestão Agrícola Inteligente",
  "main": "main.js",
  "author": "AgroFarm Digital",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.agrofarmdigital.app",
    "productName": "AgroFarm Digital",
    "copyright": "Copyright © 2025 AgroFarm Digital",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "dmg": {
        "title": "AgroFarm Digital",
        "backgroundColor": "#1a56db"
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
